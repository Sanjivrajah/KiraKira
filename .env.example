# Application
# Copy this file to .env.local for local development.
APP_URL=http://localhost:3000

# Supabase auth (browser-safe public values)
# When both values are present, sign-in and sign-up use Supabase Auth.
# When either value is missing, the app falls back to the browser-local demo auth service.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Operational database (server only)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kirakira

# Private evidence storage (server only)
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# OpenAI vision and structured extraction (server only)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_DOCUMENT_MODEL=gpt-5.4
OPENAI_TEXT_MODEL=gpt-5.4

# ElevenLabs speech-to-text (server only)
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2

# Databricks extraction, lineage and evaluation (server only)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=

# MyInvois sandbox integration (server only)
MYINVOIS_ENVIRONMENT=sandbox
MYINVOIS_API_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_IDENTITY_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET=

# Optional official-requirements search (server only)
EXA_API_KEY=
