# Copy this file to .env.local for local development.

# Web authentication and persistence
# Supabase is the default. Set demo only for the explicit browser-local demo.
NEXT_PUBLIC_AUTH_MODE=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Trusted server and worker access—never expose this through NEXT_PUBLIC_*.
# Required by the Railway bot in Supabase mode and by trusted scheduled jobs.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI extraction
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_DOCUMENT_MODEL=gpt-5.4
OPENAI_TEXT_MODEL=gpt-5.4
# Used by the Telegram transaction agent for structured text extraction.
# Prefer the gpt-5.x tier for stronger Manglish, multi-intent, and field
# reasoning; gpt-4o-mini remains a low-cost fallback with structured-output support.
OPENAI_TRANSACTION_MODEL=gpt-5.4

# ElevenLabs transcription and browser voice assistant
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_AGENT_ID=

# Telegram worker
TELEGRAM_BOT_TOKEN=
BOT_PERSISTENCE_MODE=supabase
MAX_VOICE_FILE_BYTES=20971520
LOCAL_DATA_DIRECTORY=./data

# MyInvois—server only
MYINVOIS_SANDBOX_API_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_SANDBOX_IDENTITY_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_SANDBOX_CLIENT_ID=
MYINVOIS_SANDBOX_CLIENT_SECRET=

MYINVOIS_PRODUCTION_API_BASE_URL=https://api.myinvois.hasil.gov.my
MYINVOIS_PRODUCTION_IDENTITY_BASE_URL=https://api.myinvois.hasil.gov.my
MYINVOIS_PRODUCTION_CLIENT_ID=
MYINVOIS_PRODUCTION_CLIENT_SECRET=

# Bearer secret for POST /api/internal/e-invoices/status-sync.
EINVOICE_STATUS_SYNC_SECRET=
