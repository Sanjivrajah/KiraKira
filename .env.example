# Application
# Copy this file to .env.local for local development.
APP_URL=http://localhost:3000

# Supabase mode (browser-safe)
# Use `demo` for browser-local demo records or `supabase` for real Supabase Auth.
# In production an omitted mode is treated as `supabase`, so broken configuration
# cannot silently become a demo. Keep service-role values server-only.
NEXT_PUBLIC_AUTH_MODE=demo

# Supabase Auth and API (browser-safe public values)
# For local Supabase, run `npm run supabase:status -o env` and copy the API URL
# and publishable/anon key into these two values. For hosted Supabase, use the
# project's API URL and publishable key instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional server-only elevated access. Do not set this unless a future
# server-only operation explicitly requires it; never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database URL for local tooling only. `npm run supabase:status`
# prints the local DB URL. The web application does not read this value.
SUPABASE_DB_URL=
# Telegram bot (required only when running `npm run bot:dev` or `npm run bot:start`)
TELEGRAM_BOT_TOKEN=

# Operational database (server only, existing non-Supabase integration)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kirakira

# Private evidence storage (server only)
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# OpenAI vision and structured extraction (server only)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_DOCUMENT_MODEL=gpt-5.4
OPENAI_TEXT_MODEL=gpt-5.4
# Used by the Telegram transaction agent for structured text extraction.
# gpt-4o-mini is a low-cost model with structured-output support.
OPENAI_TRANSACTION_MODEL=gpt-4o-mini

# ElevenLabs speech-to-text (server only)
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2
# Maximum accepted Telegram voice-note size (20 MiB by default).
MAX_VOICE_FILE_BYTES=20971520
# ElevenLabs Conversational AI agent for the live voice assistant (/voice).
# Server only: the browser receives a short-lived token from /api/voice/session,
# never this id or the API key directly.
ELEVENLABS_AGENT_ID=

# Use `local` only for the existing development demo. Hosted bot deployments
# must use `supabase`; the service role remains server-only.
BOT_PERSISTENCE_MODE=local
# Reserved for the Telegram transaction agent's local JSON persistence session.
LOCAL_DATA_DIRECTORY=./data

# Databricks extraction, lineage and evaluation (server only)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=

# MyInvois sandbox integration (server only)
MYINVOIS_ENVIRONMENT=sandbox
MYINVOIS_API_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_IDENTITY_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET=

# Optional official-requirements search (server only)
EXA_API_KEY=
